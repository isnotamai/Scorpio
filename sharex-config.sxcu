{
  "Version": "14.0.0",
  "Name": "Scorpio Image Uploader",
  "DestinationType": "ImageUploader",
  "RequestMethod": "POST",
  "RequestURL": "http://localhost:3000/upload",
  "Headers": {
    "X-API-Key": "YOUR-API-KEY"
  },
  "Body": "MultipartFormData",
  "FileFormName": "file",
  "URL": "{json:url}",
  "DeletionURL": "{json:delete_url}"
}
